<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Roya • Frequently Asked Questions</title>
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #F8FAFC;
            color: #1A202C;
            line-height: 1.6;
        }

        .app-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* Navigation */
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0;
            border-bottom: 1px solid #E2E8F0;
            flex-wrap: wrap;
            gap: 20px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
        }

        .logo-icon {
            background: #2B6F4B;
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 600;
            color: white;
        }

        .logo-text {
            font-size: 22px;
            font-weight: 600;
            color: #1A202C;
        }

        .nav-links {
            display: flex;
            gap: 32px;
            align-items: center;
        }

        .nav-links a {
            color: #4A5568;
            text-decoration: none;
            font-weight: 500;
            font-size: 15px;
            transition: color 0.2s;
        }

        .nav-links a:hover,
        .nav-links a.active {
            color: #2B6F4B;
        }

        .btn-outline {
            background: transparent;
            border: 1px solid #E2E8F0;
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: 500;
            color: #1A202C;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s;
        }

        .btn-outline:hover {
            border-color: #2B6F4B;
            color: #2B6F4B;
        }

        /* Page Header */
        .page-header {
            padding: 60px 0 30px;
            text-align: center;
        }

        .page-header h1 {
            font-size: 36px;
            font-weight: 700;
            color: #1A202C;
            margin-bottom: 16px;
        }

        .page-header p {
            color: #4A5568;
            font-size: 18px;
            max-width: 600px;
            margin: 0 auto;
        }

        /* FAQ Sections */
        .faq-section {
            margin-bottom: 40px;
        }

        .section-title {
            font-size: 20px;
            font-weight: 600;
            color: #2B6F4B;
            margin-bottom: 20px;
            padding-bottom: 8px;
            border-bottom: 2px solid #E2E8F0;
        }

        .faq-item {
            background: white;
            border: 1px solid #E2E8F0;
            border-radius: 12px;
            margin-bottom: 16px;
            overflow: hidden;
        }

        .faq-question {
            padding: 20px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            font-weight: 600;
            color: #1A202C;
            transition: background 0.2s;
        }

        .faq-question:hover {
            background: #F8FAFC;
        }

        .faq-question i {
            color: #2B6F4B;
            transition: transform 0.2s;
        }

        .faq-answer {
            padding: 0 24px 20px 24px;
            color: #4A5568;
            line-height: 1.6;
            display: none;
        }

        .faq-answer.visible {
            display: block;
        }

        .faq-answer p {
            margin-bottom: 12px;
        }

        .faq-answer ul {
            margin-left: 24px;
            margin-bottom: 12px;
        }

        .faq-answer li {
            margin-bottom: 4px;
        }

        .highlight {
            background: #F0F9F4;
            padding: 16px;
            border-radius: 8px;
            margin: 16px 0;
            border-left: 4px solid #2B6F4B;
        }

        /* Trust Bar */
        .trust-bar {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 32px;
            margin: 40px 0;
            padding: 20px 0;
            border-top: 1px solid #E2E8F0;
            border-bottom: 1px solid #E2E8F0;
        }

        .trust-item {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #2B6F4B;
            font-weight: 500;
            font-size: 15px;
        }

        /* Contact CTA */
        .contact-cta {
            background: #F8FAFC;
            border-radius: 16px;
            padding: 40px;
            text-align: center;
            margin: 40px 0;
            border: 1px solid #E2E8F0;
        }

        .contact-cta h3 {
            font-size: 24px;
            font-weight: 700;
            color: #1A202C;
            margin-bottom: 16px;
        }

        .contact-cta p {
            color: #4A5568;
            margin-bottom: 24px;
            max-width: 500px;
            margin-left: auto;
            margin-right: auto;
        }

        .btn-primary {
            background: #2B6F4B;
            color: white;
            border: none;
            padding: 12px 32px;
            border-radius: 40px;
            font-weight: 600;
            cursor: pointer;
            font-size: 16px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: background 0.2s;
        }

        .btn-primary:hover {
            background: #1E4F36;
        }

        /* Footer */
        footer {
            border-top: 1px solid #E2E8F0;
            padding: 40px 0;
            margin-top: 40px;
            text-align: center;
            color: #718096;
        }

        /* Site color scheme overrides (matches landing page) */
        :root {
            --bg-main: #0a0a0a;
            --bg-elev: #111111;
            --bg-soft: #151515;
            --text-main: #e0e0e0;
            --text-dim: #9ca3af;
            --line: rgba(34, 211, 238, 0.25);
            --accent: #22d3ee;
            --accent-2: #22d3ee;
        }

        body {
            background: var(--bg-main);
            color: var(--text-main);
        }

        nav {
            border-bottom-color: var(--line);
            background: #000000;
            border-radius: 14px;
            padding: 16px 20px;
            margin-top: 14px;
        }

        .logo-icon {
            background: var(--accent);
            color: #000000;
        }

        .logo-text,
        .page-header h1,
        .faq-question,
        .contact-cta h3 {
            color: var(--text-main);
        }

        .page-header p,
        .faq-answer,
        .contact-cta p,
        .nav-links a,
        footer {
            color: var(--text-dim);
        }

        .nav-links a:hover,
        .nav-links a.active,
        .section-title,
        .trust-item,
        .faq-question i {
            color: var(--accent-2);
        }

        .btn-primary {
            background: var(--accent);
            color: #000000;
        }

        .btn-primary:hover { background: #06b6d4; }

        .btn-outline {
            border-color: var(--line);
            color: var(--text-main);
            background: rgba(17, 17, 17, 0.45);
        }

        .btn-outline:hover {
            border-color: var(--accent);
            color: var(--text-main);
        }

        .section-title {
            border-bottom-color: var(--line);
        }

        .faq-item,
        .contact-cta {
            background: var(--bg-elev);
            border-color: var(--line);
        }

        .faq-question:hover {
            background: var(--bg-soft);
        }

        .highlight {
            background: rgba(34, 211, 238, 0.1);
            border-left-color: var(--accent);
            color: var(--text-main);
        }

        .trust-bar,
        footer {
            border-color: var(--line);
        }

        @media (max-width: 600px) {
            .trust-bar {
                flex-direction: column;
                align-items: center;
                gap: 16px;
            }
        }
    </style>
</head>
<body>
    <div class="app-container">
        <!-- Navigation -->
        <nav>
            <a href="/index.html" class="logo" style="text-decoration:none;">
                <div class="logo-icon">R</div>
                <span class="logo-text">Roya</span>
            </a>
            <div class="nav-links">
                <a href="/index.html">Home</a>
                <a href="/pages/review.html">Analyze Metadata</a>
                <a href="/see.html">How It Works</a>
                <a href="/pilot.html">Pilot Program</a>
            </div>
        </nav>

        <!-- Page Header -->
        <div class="page-header">
            <h1>Frequently Asked Questions</h1>
            <p>For PRO and publishing partners evaluating Roya</p>
        </div>

        <!-- Trust Bar (Reinforces key messages) -->
        <div class="trust-bar">
            <div class="trust-item"><i class="fas fa-check-circle"></i> No integration required</div>
            <div class="trust-item"><i class="fas fa-check-circle"></i> No workflow change</div>
            <div class="trust-item"><i class="fas fa-check-circle"></i> PRO remains final authority</div>
            <div class="trust-item"><i class="fas fa-check-circle"></i> Pilot-ready</div>
        </div>

        <!-- FAQ Sections -->
        <div class="faq-section">
            <div class="section-title">PRO Integration & Authority</div>
            
            <div class="faq-item">
                <div class="faq-question" onclick="toggleFAQ(this)">
                    Does Roya replace PRO or PRO's payment systems?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="faq-answer">
                    <p><strong>No.</strong> Roya is a pre-submission verification layer only. We do not touch money, do not replace societies, and do not change your workflow. We simply catch errors before they reach PRO's queue.</p>
                    <p>PRO's validation remains the final authority for all registrations. If Roya misses something, PRO's process catches it as normal.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question" onclick="toggleFAQ(this)">
                    Does Roya require changes to PRO's systems or CUBE integration?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="faq-answer">
                    <p><strong>No integration required.</strong> Roya operates as a standalone pre-submission layer for publishers. There are no changes to PRO's existing IT systems, no CUBE code modifications, and no timeline dependencies.</p>
                    <p>Publishers upload their PRO registration CSVs to Roya, we validate them, and they receive verified files ready for submission to PRO — using exactly the same workflow they use today.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question" onclick="toggleFAQ(this)">
                    What if Roya's verification is incorrect?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="faq-answer">
                    <p>PRO's validation is still the final authority. Roya is an additional check, not a replacement. If we miss something, PRO's process catches it as normal — exactly as it does today.</p>
                    <p>The pilot will measure both false positives and false negatives to ensure accuracy.</p>
                </div>
            </div>
        </div>

        <div class="faq-section">
            <div class="section-title">Data & Privacy</div>
            
            <div class="faq-item">
                <div class="faq-question" onclick="toggleFAQ(this)">
                    What data does Roya store? Is it GDPR compliant?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="faq-answer">
                    <p>Roya stores only the data needed for verification: contributor names, roles, percentages, and IPI/ISWC identifiers from split sheets. All personal data is stored in secure, encrypted infrastructure compliant with GDPR and applicable Swedish data protection regulations.</p>
                    <p>We do not store payment data, bank details, or sensitive personal information beyond what's already in PRO submissions.</p>
                    <div class="highlight">
                        <strong>Data Protection Statement:</strong> All personal and contractual data are stored off-chain in secure infrastructure compliant with applicable data protection regulations. The blockchain stores only a cryptographic fingerprint — no personal data.
                    </div>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question" onclick="toggleFAQ(this)">
                    Why blockchain instead of a regular database?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="faq-answer">
                    <p>Blockchain provides an independent, tamper-proof timestamp. In disputes, neither party can claim the verification was altered after the fact. It serves as a neutral third-party record.</p>
                    <p>The blockchain stores only a cryptographic fingerprint (hash) of the document — no personal data, no contractual terms, no financial information. It's simply a timestamped proof that the file existed at a specific point in time.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question" onclick="toggleFAQ(this)">
                    Can PRO access the verification records?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="faq-answer">
                    <p>Yes. During the pilot, we'll establish data-sharing protocols so PRO can verify the audit trail for any disputed registrations. Publishers can also share their verification reports directly with PRO when questions arise.</p>
                </div>
            </div>
        </div>

        <div class="faq-section">
            <div class="section-title">Pilot & Measurement</div>
            
            <div class="faq-item">
                <div class="faq-question" onclick="toggleFAQ(this)">
                    What does the pilot cost PRO?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="faq-answer">
                    <p><strong>Zero cost to PRO.</strong> The pilot is fully funded by Roya. Participating publishers use the service at no cost during the evaluation period. There are no integration costs, no licensing fees, and no financial commitment from PRO.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question" onclick="toggleFAQ(this)">
                    How will success be measured?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="faq-answer">
                    <p>We'll track four key metrics:</p>
                    <ul>
                        <li><strong>Rejection rate reduction:</strong> Target 20-30% decrease in split-related corrections for pilot publishers</li>
                        <li><strong>Processing speed:</strong> Time from submission to completion (target: days instead of weeks)</li>
                        <li><strong>Admin time saved:</strong> PRO staff hours spent on manual corrections (target: 3,000+ hours/year at scale)</li>
                        <li><strong>Workflow impact:</strong> Zero disruption to existing processes</li>
                    </ul>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question" onclick="toggleFAQ(this)">
                    What happens after the pilot?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="faq-answer">
                    <p>After the 5-month pilot, we'll present a comprehensive report to PRO leadership with findings, metrics, and recommendations. Based on results, we can discuss:</p>
                    <ul>
                        <li>Extending the pilot to additional publishers</li>
                        <li>Long-term operational integration models</li>
                        <li>Potential for PRO-endorsed verification standard</li>
                    </ul>
                    <p>There is no obligation to continue beyond the pilot period.</p>
                </div>
            </div>
        </div>

        <div class="faq-section">
            <div class="section-title">Publisher Experience</div>
            
            <div class="faq-item">
                <div class="faq-question" onclick="toggleFAQ(this)">
                    What do publishers need to change in their workflow?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="faq-answer">
                    <p>Almost nothing changes. Publishers who already export PRO CSV files can upload them to Roya, receive a verification report, and fix any issues before submitting to PRO. The workflow is:</p>
                    <ol style="margin-left: 24px; margin-bottom: 12px;">
                        <li>Export CSV from their existing system (same as today)</li>
                        <li>Upload to Roya (new 2-minute step)</li>
                        <li>Review issues and auto-fix if desired</li>
                        <li>Download verified file and submit to PRO (same as today)</li>
                    </ol>
                    <p>No system integration required, no software to install, no training needed.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question" onclick="toggleFAQ(this)">
                    What happens when publishers upload error-free data?
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="faq-answer">
                    <p>They receive a verification record confirming the data is clean and can submit directly to PRO with confidence. The verification record provides an audit trail that can be referenced if questions arise later.</p>
                </div>
            </div>
        </div>

        <!-- Contact CTA -->
        <div class="contact-cta">
            <h3>Still have questions?</h3>
            <p>We're happy to discuss the pilot, data privacy, or technical architecture in more detail.</p>
            <button class="btn-primary" onclick="window.location.href='#'">
                <i class="far fa-envelope"></i>
                Contact Pilot Team
            </button>
        </div>

        <!-- Footer -->
        <footer>
            <p>Roya supports PRO's data quality and operational efficiency goals through upstream verification.</p>
            <div style="margin-top: 16px; display:flex; gap:24px; flex-wrap:wrap; justify-content:center;">
                <a href="/index.html" style="color:inherit;">Home</a>
                <a href="/pages/review.html" style="color:inherit;">Analyze Metadata</a>
                <a href="/pilot.html" style="color:inherit;">Pilot Program</a>
                <a href="/FAQ.html" style="color:inherit;">FAQ</a>
                <a href="/documents.html" style="color:inherit;">Documents</a>
                <a href="/privacy.html" style="color:inherit;">Privacy</a>
            </div>
            <div style="margin-top: 16px;">
                <span>© 2026 Roya</span>
                <span style="margin:0 12px;">|</span>
                <span>PRO Compatible</span>
                <span style="margin:0 12px;">|</span>
                <span>Built for Swedish Publishing</span>
            </div>
        </footer>
    </div>

    <script>
        function toggleFAQ(element) {
            const answer = element.nextElementSibling;
            const icon = element.querySelector('i');
            
            answer.classList.toggle('visible');
            
            if (answer.classList.contains('visible')) {
                icon.className = 'fas fa-chevron-up';
            } else {
                icon.className = 'fas fa-chevron-down';
            }
        }
    </script>
</body>
</html>


