          {/* Run Due Diligence Section */}
          {activeSection === 'run-due-diligence' && (
            <div className="bg-white rounded-xl border border-gray-200 p-8">
              <h1 className="text-2xl font-bold text-gray-900 mb-4">Run Catalog Due Diligence</h1>
              <p className="text-gray-600 mb-4">Matter: {matter.name}</p>
              
              <div className="grid md:grid-cols-3 gap-4 mb-6">
                <div className="p-4 border border-gray-200 rounded-lg">
                  <p className="text-sm text-gray-600">Recoupment Status</p>
                  <p className="text-lg font-semibold text-green-600">Recouped</p>
                  <p className="text-xs text-gray-500">Artist owed $12,500</p>
                </div>
                <div className="p-4 border border-gray-200 rounded-lg">
                  <p className="text-sm text-gray-600">Missing IPI/ISRC</p>
                  <p className="text-lg font-semibold text-red-600">3 issues</p>
                  <p className="text-xs text-gray-500">Not PRO-ready</p>
                </div>
                <div className="p-4 border border-gray-200 rounded-lg">
                  <p className="text-sm text-gray-600">Dispute Timer</p>
                  <p className="text-lg font-semibold text-orange-600">14 days left</p>
                  <p className="text-xs text-gray-500">Resolution required</p>
                </div>
              </div>

              <button
                onClick={runScan}
                disabled={downloading === 'scan'}
                className="px-6 py-3 bg-indigo-900 text-white rounded-lg hover:bg-indigo-800 transition disabled:opacity-50"
              >
                {downloading === 'scan' ? 'Scanning...' : 'Start Scan'}
              </button>
              {scanComplete && (
                <div className="mt-4 p-4 bg-green-50 border border-green-200 rounded-lg">
                  <p className="text-green-800">✓ Scan complete! Audit trail generated.</p>
                </div>
              )}
            </div>
          )}

          {/* View Audit Report Section */}
          {activeSection === 'view-audit-report' && (
            <div className="bg-white rounded-xl border border-gray-200 p-8">
              <h1 className="text-2xl font-bold text-gray-900 mb-4">View Audit Report</h1>
              <p className="text-gray-600 mb-4">Matter: {matter.name}</p>
              
              <div className="space-y-4">
                <div className="flex items-center justify-between p-4 border border-gray-100 rounded-lg hover:bg-indigo-50 cursor-pointer" onClick={() => setShowPdfPreview(true)}>
                  <div>
                    <h3 className="font-medium text-gray-900">Q4 2025 Audit Report</h3>
                    <p className="text-sm text-gray-500">Generated: Feb 15, 2026 • Hash: 0x7a3f...b8e2</p>
                  </div>
                  <button className="text-indigo-600">Preview</button>
                </div>
              </div>

              {/* PDF Preview Modal */}
              {showPdfPreview && (
                <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
                  <div className="bg-white rounded-xl p-6 max-w-4xl w-full max-h-[80vh] overflow-y-auto">
                    <div className="flex justify-between items-center mb-4">
                      <h3 className="text-lg font-semibold">Audit Report Preview</h3>
                      <button onClick={() => setShowPdfPreview(false)} className="text-gray-500 hover:text-gray-700">✕</button>
                    </div>
                    <div className="border rounded-lg p-8 bg-gray-50 min-h-[400px] flex items-center justify-center">
                      <p className="text-gray-400">PDF preview would appear here using react-pdf</p>
                    </div>
                  </div>
                </div>
              )}
            </div>
          )}

          {/* Generate Court Report Section */}
          {activeSection === 'generate-court-report' && (
            <div className="bg-white rounded-xl border border-gray-200 p-8">
              <h1 className="text-2xl font-bold text-gray-900 mb-4">Generate Court-Ready Report</h1>
              <p className="text-gray-600 mb-4">Matter: {matter.name}</p>
              <button
                onClick={() => handleDownload('court', 'Court Report', matter.name, matter.id)}
                disabled={downloading === 'court'}
                className="px-6 py-3 bg-indigo-900 text-white rounded-lg hover:bg-indigo-800 transition disabled:opacity-50"
              >
                {downloading === 'court' ? 'Generating...' : 'Generate Court Report'}
              </button>
            </div>
          )}

          {/* Create Demand Letter Section */}
          {activeSection === 'create-demand-letter' && (
            <div className="bg-white rounded-xl border border-gray-200 p-8">
              <h1 className="text-2xl font-bold text-gray-900 mb-4">Create Demand Letter</h1>
              <p className="text-gray-600 mb-4">Matter: {matter.name}</p>
              
              <div className="space-y-4 max-w-2xl">
                <div className="flex gap-4">
                  <button className="flex-1 bg-indigo-900 text-white py-2 rounded-lg hover:bg-indigo-800">
                    Generate Standard
                  </button>
                  <button className="flex-1 bg-yellow-600 text-white py-2 rounded-lg hover:bg-yellow-700">
                    Request Revision
                  </button>
                </div>
              </div>
            </div>
          )}

          {/* Export Affidavit Section */}
          {activeSection === 'export-affidavit' && (
            <div className="bg-white rounded-xl border border-gray-200 p-8">
              <h1 className="text-2xl font-bold text-gray-900 mb-4">Export Affidavit</h1>
              <p className="text-gray-600 mb-4">Matter: {matter.name}</p>
              <button
                onClick={() => handleDownload('affidavit', 'Affidavit', matter.name, matter.id)}
                disabled={downloading === 'affidavit'}
                className="px-6 py-3 bg-indigo-900 text-white rounded-lg hover:bg-indigo-800 transition disabled:opacity-50"
              >
                {downloading === 'affidavit' ? 'Generating...' : 'Export Affidavit'}
              </button>
            </div>
          )}

          {/* Export Hash Seal Section */}
          {activeSection === 'export-hash-seal' && (
            <div className="bg-white rounded-xl border border-gray-200 p-8">
              <h1 className="text-2xl font-bold text-gray-900 mb-4">Export with Hash Seal</h1>
              <p className="text-gray-600 mb-4">Matter: {matter.name}</p>
              <button
                onClick={() => handleDownload('hash', 'Hash-Sealed Document', matter.name, matter.id)}
                disabled={downloading === 'hash'}
                className="px-6 py-3 bg-indigo-900 text-white rounded-lg hover:bg-indigo-800 transition disabled:opacity-50"
              >
                {downloading === 'hash' ? 'Generating...' : 'Export with Hash Seal'}
              </button>
            </div>
          )}

          {/* Secure Message Section */}
          {activeSection === 'secure-message' && (
            <div className="bg-white rounded-xl border border-gray-200 p-8">
              <h1 className="text-2xl font-bold text-gray-900 mb-4">Secure Client Message</h1>
              <p className="text-gray-600 mb-4">You have 2 unread messages.</p>
              
              <div className="space-y-4">
                <div className="p-4 border border-gray-200 rounded-lg">
                  <div className="flex justify-between mb-2">
                    <span className="font-medium">Client A</span>
                    <span className="text-xs text-gray-500">2 hours ago</span>
                  </div>
                  <p className="text-sm text-gray-600">Please review the updated split sheet...</p>
                </div>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
