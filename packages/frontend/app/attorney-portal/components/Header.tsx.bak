                <circle cx="17" cy="17" r="15" stroke="#818cf8" strokeWidth="1.6" fill="none"/>
                <polygon points="17,7 24.5,11.25 24.5,19.75 17,24 9.5,19.75 9.5,11.25" stroke="#6366f1" strokeWidth="1.6" fill="none"/>
                <polyline points="11.5,17 15,20.5 22.5,13" stroke="#818cf8" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/>
              </svg>
              <span style={{fontFamily:"Inter,-apple-system,sans-serif",fontWeight:600,fontSize:"14px",color:"#c7d2fe",letterSpacing:"-0.01em",whiteSpace:"nowrap",lineHeight:1}}>TrapRoyalties<span style={{fontWeight:800,color:"#818cf8",letterSpacing:"0.08em"}}>PRO</span></span>
            </Link>
            <span style={{padding:"4px 14px",background:"rgba(99,102,241,0.15)",border:"1px solid rgba(99,102,241,0.35)",color:"#a5b4fc",borderRadius:"999px",fontSize:"11px",fontWeight:600,letterSpacing:"0.06em",whiteSpace:"nowrap"}}>
